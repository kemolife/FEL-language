{
    "name": "kemolife/fel-language",
    "description": "FEL (Flexible Executed Language) interpreter and compiler",
    "type": "project",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Fel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Fel\\Tests\\": "tests/"
        }
    },
    "bin": ["bin/fel"],
    "config": {
        "optimize-autoloader": true
    }
}
