{
  "sqrt": fn(x) { sqrt(x) },
  "pow": fn(x, y) { pow(x, y) },
  "abs": fn(x) { abs(x) },
  "floor": fn(x) { floor(x) },
  "ceil": fn(x) { ceil(x) },
  "round": fn(x) { round(x) },
  "min": fn(a, b) { min(a, b) },
  "max": fn(a, b) { max(a, b) },
  "log": fn(x) { log(x) },
  "sin": fn(x) { sin(x) },
  "cos": fn(x) { cos(x) },
  "tan": fn(x) { tan(x) },
  "pi": 3.14159265358979,
  "e": 2.71828182845905
}
